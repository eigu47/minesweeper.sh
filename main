#!/usr/bin/env bash

# constants
declare -Ar BOX=(
	[HH]='═'
	[VV]='║'
	[TL]='╔'
	[TR]='╗'
	[BR]='╝'
	[BL]='╚'
	[ML]='╠'
	[MT]='╦'
	[MR]='╣'
	[MB]='╩'
	[H]='─'
	[V]='│'
	[X]='┼'
)

declare -Ar DIRS=(
	[UL]='-1 -1'
	[UP]='-1 0'
	[UR]='-1 1'
	[RG]='0 1'
	[DR]='1 1'
	[DW]='1 0'
	[DL]='1 -1'
	[LF]='0 -1'
)

declare -Ar STYLE=(
	[GRAY]='\e[100m'
	[GREEN]='\e[102m'
	[RST]='\e[0m'
	[1]='\e[1;34m' # blue
	[2]='\e[1;32m' # green
	[3]='\e[1;31m' # red
	[4]='\e[1;35m' # purple
	[5]='\e[1;33m' # yellow
	[6]='\e[1;36m' # cyan
	[7]='\e[1;30m' # black
	[8]='\e[1;37m' # white
	[*]='\e[1;41m' # red bg
)

# default state
width=8
height=8
total_mines=10
player_pos=0 # pos=-1 lose, pos=-2 win
board=()
mines=()
declare -A selected=()

fatal() {
	echo '[FATAL]:' "$*" >&2
	exit 1
}

usage() {
	cat <<-EOF
		Usage: ${0##*/} <day> [part]
		Options:
	EOF

	exit 0
}

parse_args() {
	while getopts "h" opt; do
		case "$opt" in
		h) usage ;;
		\?) fatal "invalid argument: -$OPTARG" ;;
		esac
	done
	shift $((OPTIND - 1))
}

repeat() {
	local s
	printf -v s "%*s" "$2" ""
	printf "%s" "${s// /$1}"
}

# xy to idx
get_idx() {
	local row="$1" col="$2"
	if ((row < 0 || col < 0 || row >= width || col >= height)); then
		return 1
	fi

	echo $((row * width + col))
}

# idx to xy
get_grid() {
	local idx="$1"
	local row=$((idx / width)) col=$((idx % width))
	if ((row < 0 || col < 0 || row >= width || col >= height)); then
		return 1
	fi

	echo $row $col
}

# move idx by xy
get_idx_dir() {
	local idx="$1" dx="$2" dy="$3"
	local -a grid_arr
	read -r -a grid_arr <<<"$(get_grid "$idx")" || return 1
	idx=$(get_idx $((grid_arr[0] + dx)) $((grid_arr[1] + dy))) || return 1
	echo "$idx"
}

init_board() {
	# reset game
	board=()
	mines=()
	selected=()
	player_pos=0

	# initiate board
	local i
	for ((i = 0; i < width * height; i++)); do
		board+=(0)
	done

	# set mines
	local pos
	while ((${#mines[@]} < total_mines)); do
		pos=$((RANDOM % (width * height)))
		[[ ${board[pos]} == '*' ]] && continue
		board[pos]='*'
		mines+=("$pos")
	done

	# calculate sides
	local idx dir dx dy
	for idx in "${mines[@]}"; do
		# loop over all directions, sum 1 if is empty
		for dir in "${DIRS[@]}"; do
			read -r dx dy <<<"$dir"
			pos=$(get_idx_dir "$idx" "$dx" "$dy") || continue
			[[ ${board[$pos]} == '*' ]] && continue
			((board[pos]++))
		done
	done
}

get_tile() {
	local pos="$1" color cell=" "
	local val="${board[$pos]}"

	# game over
	if ((player_pos < 0)); then
		if [[ ! -n ${selected[$pos]} && $val != '*' ]]; then
			color="${STYLE[GRAY]}"
		fi

		if [[ $val != '0' ]]; then
			cell="$val"
		fi

		# for wins, green bg mine
		if [[ $val == '*' ]] && ((player_pos == -2)); then
			color="${STYLE[GREEN]}"
		else
			color+="${STYLE[$val]}"
		fi

		echo "$color $cell ${STYLE[RST]}"
		return
	fi

	if [[ -n ${selected[$pos]} ]]; then
		if ((val != 0)); then
			color="${STYLE[$val]}"
			cell="$val"
		fi
	else
		color="${STYLE[GRAY]}"
	fi

	if ((pos == player_pos)); then
		color="${STYLE[GREEN]}"
	fi

	echo "$color $cell ${STYLE[RST]}"
}

draw() {
	# reset terminal
	tput cup 0 0

	local grid_w=$((width * 4 - 1))

	# top box
	local grid="${BOX[TL]}"
	grid+=$(repeat "${BOX[HH]}" $grid_w)
	grid+="${BOX[TR]}\n"

	# mines left + face
	grid+="${BOX[VV]}  ${total_mines}"
	grid+=$(repeat " " $((grid_w / 2 - 2 - ${#total_mines})))

	case "$player_pos" in
	-1) grid+=':(' ;;
	-2) grid+='8)' ;;
	*) grid+=':)' ;;
	esac

	grid+=$(repeat " " $((grid_w / 2 - 1)))
	grid+="${BOX[VV]}\n"

	# top line
	grid+="${BOX[ML]}"
	grid+=$(repeat "${BOX[HH]}" $grid_w)
	grid+="${BOX[MR]}\n"

	# rows
	local h i cell color idx val
	for ((h = 0; h < height; h++)); do
		grid+="${BOX[VV]}"
		for ((i = 0; i < width; i++)); do
			# get tile display
			idx=$(get_idx $h $i)
			grid+=$(get_tile "$idx")
			((i < width - 1)) && grid+="${BOX[V]}"
		done
		grid+="${BOX[VV]}\n"

		# row separators
		if ((h < height - 1)); then
			grid+="${BOX[VV]}"
			for ((i = 0; i < width; i++)); do
				grid+="${BOX[H]}${BOX[H]}${BOX[H]}"
				((i < width - 1)) && grid+="${BOX[X]}"
			done
			grid+="${BOX[VV]}\n"
		fi
	done

	# bottom line
	grid+="${BOX[BL]}"
	grid+=$(repeat "${BOX[HH]}" $grid_w)
	grid+="${BOX[BR]}"

	echo -e "$grid"
}

move_player() {
	# if game is over, dont move
	((player_pos < 0)) && return 1

	local dir="$1" dx dy row col
	read -r dx dy <<<"$dir"
	read -r row col <<<"$(get_grid "$player_pos")"

	# calculate new pos, wrap-around
	row=$(((row + dx + height) % height))
	col=$(((col + dy + width) % width))
	player_pos=$(get_idx "$row" "$col")
}

select_tile() {
	local pos="$1"
	# already selected tiles does nothing
	if [[ -n "${selected[$pos]}" ]]; then
		return
	fi

	# if its a mine, game over
	if [[ ${board[$pos]} == '*' ]]; then
		player_pos=-1
		return
	fi

	selected[$pos]=1

	# if all non mines are selected, win
	if ((${#selected[@]} + total_mines == width * height)); then
		player_pos=-2
		return
	fi

	# recurse over all directions if theres no mines
	local dir dx dy idx
	if ((${board[$pos]} == 0)); then
		for dir in "${DIRS[@]}"; do
			read -r dx dy <<<"$dir"
			idx=$(get_idx_dir "$pos" "$dx" "$dy") || continue
			select_tile "$idx"
		done
	fi
}

handle_input() {
	local key rest

	IFS= read -rsn1 key
	if [[ $key == $'\e' ]]; then
		read -rsn2 rest
		key+="$rest"
	fi

	case "$key" in
	$'\e[A' | w) move_player "${DIRS[UP]}" ;;
	$'\e[B' | s) move_player "${DIRS[DW]}" ;;
	$'\e[C' | d) move_player "${DIRS[RG]}" ;;
	$'\e[D' | a) move_player "${DIRS[LF]}" ;;
	' ') select_tile "$player_pos" ;;
	r) init_board ;;
	*) return 1 ;;
	esac
}

main() {
	parse_args

	# clear terminal
	stty -echo
	tput clear
	tput civis

	init_board
	draw

	while true; do
		handle_input && draw
	done
}

cleanup() {
	stty echo
	tput sgr0
	tput cnorm
	exit 0
}
trap cleanup INT TERM EXIT

main
